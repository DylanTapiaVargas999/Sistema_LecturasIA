' ============================================================
' DIAGRAMA 1 — CU-0001: Gestionar Autenticación y Autorización
' ============================================================
@startuml CU0001_Paquetes

left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
scale 0.75

skinparam package {
  BackgroundColor #EEF2FF
  BorderColor #6366F1
  FontColor #1E1B4B
  FontStyle bold
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #A5B4FC
  FontColor #312E81
  FontSize 9
}

title <b>CU-0001 — Gestionar Autenticación y Autorización</b>\nDiagrama de Paquetes (Vista de Desarrollo — Figura 107)

together {
  package "LecturaIA.API" as API1 {

    package "Configuration" as CFG1 {
      [EmailSettings.cs] as ES1
    }

    package "Controllers" as CTRL1 {
      [AuthController.cs] as AC1
      [PasswordController.cs] as PC1
    }

    package "Services" as SVC1 {
      [AuthService.cs] as AS1
      [IAuthService.cs] as IAS1
      [EmailService.cs] as EMS1
      [IEmailService.cs] as IEMS1
      [PasswordService.cs] as PS1
      [IPasswordService.cs] as IPS1
    }

    package "Models/DTOs" as DTOS1 {
      [LoginDto.cs] as LD1
      [AuthResponseDto.cs] as ARD1
      [RegistroEstudianteDto.cs] as RED1
      [RegistroDocenteDto.cs] as RDD1
      [VerificacionEmailDto.cs] as VED1
      [RecuperacionPasswordDto.cs] as RPD1
      [VerificarCodigoLoginDto.cs] as VCL1
      [PasswordDTOs.cs] as PDT1
    }

    package "Models/Entities" as ENT1 {
      [Usuario.cs] as USR1
      [Estudiante.cs] as EST1
      [Docente.cs] as DOC1
      [CodigoVerificacionLogin.cs] as CVL1
      [GradoEscolar.cs] as GE1
    }

    package "Data" as DATA1 {
      [ApplicationDbContext.cs] as DBX1
    }
  }
}

together {
  package "LecturaIA.Frontend" as FE1 {

    package "pages" as PAGES1 {
      [DocenteAuth.tsx] as DA1
      [EstudianteAuth.tsx] as EA1
      [VerificarEmail.tsx] as VE1
      [RecuperarPassword.tsx] as RP1
    }

    package "components" as COMP1 {
      [VerificacionCodigo.tsx] as VC1
      [CambiarPasswordModal.tsx] as CPM1
      [ProtectedRoute.tsx] as PR1
    }

    package "services" as FSVC1 {
      [authService.ts] as AUTHS1
      [passwordService.ts] as PWDS1
    }

    package "context" as CTX1 {
      [AuthContext.tsx] as CTX_A1
    }

    package "hooks" as HK1 {
      [useAuth.ts] as UA1
    }

    package "config" as FCFG1 {
      [api.ts] as API_TS1
    }
  }
}

' Frontend services --> API Controllers
AUTHS1  --> AC1  : HTTP REST
PWDS1   --> PC1  : HTTP REST

' Controllers --> Services
AC1 --> AS1
AC1 --> IAS1
PC1 --> PS1
PC1 --> IPS1

' Services --> Data
AS1   --> DBX1
PS1   --> DBX1
EMS1  --> DBX1

' Services inter
AS1    --> EMS1
IEMS1  --> EMS1
IAS1   --> AS1
IPS1   --> PS1

' Configuration --> Services
ES1 --> EMS1

' Entities --> Data
USR1 --> DBX1
EST1 --> DBX1
DOC1 --> DBX1
CVL1 --> DBX1
GE1  --> DBX1

' Frontend internal
UA1      --> CTX_A1
API_TS1  --> AUTHS1
API_TS1  --> PWDS1

@enduml


