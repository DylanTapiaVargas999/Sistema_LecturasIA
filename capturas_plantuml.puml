    }

    package "Data" as DATA4 {
      [ApplicationDbContext.cs] as DBX4
    }
  }

  package "LecturaIA.Frontend" as FE4 {

    package "pages" as PAGES4 {
      [CuestionarioGeneracion.tsx] as CG4
      [LecturaDetalle.tsx] as LDET4
    }

    package "services" as FSVC4 {
      [lecturaService.ts] as LS4
    }

